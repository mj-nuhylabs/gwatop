	<string>과탑</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>GIDC</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.166115611136-d42e728kfojf7resv9um0fcpgeffo8lp</string>
			</array>
		</dict>
	</array>
	<key>GIDClientID</key>
	<string>166115611136-d42e728kfojf7resv9um0fcpgeffo8lp.apps.googleusercontent.com</string>
	<key>GwaTopAPIBaseURL</key>
	<!--
	  임시(2026-05-30): api.gwatop.com DNS/HTTPS 셋업 완료 전까지 EC2 호스트 직결.
	  HTTPS 전환 완료 후 https://api.gwatop.com 로 복귀 + 아래 compute-1 ATS 예외 제거.
	-->
	<string>http://ec2-3-221-89-155.compute-1.amazonaws.com:8000</string>
	<!-- Pretendard Variable — gwatop-web 와 동일한 한글+라틴 단일 가변 폰트 -->
	<key>UIAppFonts</key>
	<array>
		<string>PretendardVariable.ttf</string>
	</array>
	<!--
	  Apple 캘린더 통합 — EventKit 읽기 권한.
	  iOS 17+ 는 NSCalendarsFullAccessUsageDescription 필요 (write 도 가능한 풀 액세스).
	  iOS 16 이하는 NSCalendarsUsageDescription 으로 fallback.
	  현재 통합은 read-only — 사용자의 Apple 캘린더 이벤트를 우리 캘린더에 함께 표시만 함.
	-->
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Apple 캘린더의 일정을 과탑 캘린더에 함께 표시해드려요. 일정을 수정하거나 추가하지는 않아요.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>Apple 캘린더의 일정을 과탑 캘린더에 함께 표시해드려요.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<!--
			  임시(2026-05-30): EC2 Public DNS 직결용 cleartext HTTP 예외.
			  compute-1.amazonaws.com = us-east-1 EC2 DNS suffix (서브도메인 포함).
			  api.gwatop.com HTTPS 전환 완료 시 이 블록 통째로 제거.
			-->
			<key>compute-1.amazonaws.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
