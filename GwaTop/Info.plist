<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- 홈 스크린/스위처에 표시되는 한글 이름. CFBundleName(=GwaTop) 보다 우선. -->
	<key>CFBundleDisplayName</key>
	<string>과탑</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>GIDC</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.166115611136-d42e728kfojf7resv9um0fcpgeffo8lp</string>
			</array>
		</dict>
	</array>
	<key>GIDClientID</key>
	<string>166115611136-d42e728kfojf7resv9um0fcpgeffo8lp.apps.googleusercontent.com</string>
	<!-- Pretendard Variable — gwatop-web 와 동일한 한글+라틴 단일 가변 폰트 -->
	<key>UIAppFonts</key>
	<array>
		<string>PretendardVariable.ttf</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<!--
			  EC2 Public DNS 형식: ec2-N-N-N-N.compute-1.amazonaws.com
			  IP가 바뀌어도 도메인 suffix 는 유지되므로 상위 도메인 한 번에 예외 처리.
			  운영 출시 전에는 HTTPS + 자체 도메인으로 교체 권장 — Apple 심사 시 ATS 예외에
			  대해 사유서 요구 가능.
			-->
			<key>compute-1.amazonaws.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
			<key>compute.amazonaws.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
